<Page x:Class="SignLanguageLearn.Views.LessonsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="LessonsPage" Background="{DynamicResource BackgroundBrush}">

    <Page.Resources>
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                        Background="{TemplateBinding Background}" 
                        CornerRadius="15" 
                        BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#455A64"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#37474F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid x:Name="ContentGrid" Margin="40">
        <UniformGrid x:Name="CategoryMenu" Columns="2" VerticalAlignment="Center" Visibility="Visible">
            <Button Click="Category_Click" Tag="Alphabet" Margin="15" Height="200" Style="{StaticResource ModernButtonStyle}">
                <StackPanel>
                    <TextBlock Text="🔤" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Алфавіт" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Click="Category_Click" Tag="Phrases" Margin="15" Height="200" Style="{StaticResource ModernButtonStyle}">
                <StackPanel>
                    <TextBlock Text="👋" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Базові фрази" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
        </UniformGrid>

        <Grid x:Name="LessonContent" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Button Content="← Назад" Click="BackToMenu_Click" Width="100" Height="40" 
                        Style="{StaticResource ModernButtonStyle}" HorizontalAlignment="Left" Margin="0,0,0,20"/>

                <ListBox x:Name="ItemsList" Height="450" 
                         DisplayMemberPath="Title"
                         Background="{DynamicResource CardBrush}" 
                         BorderThickness="0"
                         Foreground="{DynamicResource TextBrush}"
                         SelectionChanged="ItemsList_SelectionChanged"
                         ScrollViewer.VerticalScrollBarVisibility="Hidden">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="15,10"/>
                            <Setter Property="FontSize" Value="18"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </StackPanel>

            <Grid Grid.Column="1" Margin="30,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="Black" CornerRadius="20" ClipToBounds="True" Margin="5">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Direction="270" RenderingBias="Quality" ShadowDepth="2" Opacity="0.3"/>
                    </Border.Effect>
                    <MediaElement x:Name="LessonVideo" LoadedBehavior="Manual" UnloadedBehavior="Stop" 
                                  Stretch="Uniform" MediaEnded="LessonVideo_MediaEnded"/>
                </Border>

                <StackPanel Grid.Row="1" Margin="0,20,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                        <TextBlock Text="🐌" FontSize="25" VerticalAlignment="Center" Margin="0,0,10,0" 
                   Foreground="{DynamicResource TextBrush}"/>

                        <Slider x:Name="SpeedSlider" Width="200" Minimum="0.2" Maximum="1.0" Value="1.0" 
                TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="SpeedSlider_ValueChanged"
                VerticalAlignment="Center"/>

                        <TextBlock Text="🐇" FontSize="25" VerticalAlignment="Center" Margin="10,0,0,0" 
                   Foreground="{DynamicResource TextBrush}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="↺" Width="60" Height="50" Margin="10,0" Click="Restart_Click" Style="{StaticResource ModernButtonStyle}" FontSize="24"/>
                        <Button Content="▶" Width="80" Height="50" Margin="10,0" Click="Play_Click" Style="{StaticResource ModernButtonStyle}" FontSize="24"/>
                        <Button Content="⏸" Width="80" Height="50" Margin="10,0" Click="Pause_Click" Style="{StaticResource ModernButtonStyle}" FontSize="24"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>