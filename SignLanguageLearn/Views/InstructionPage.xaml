<Page x:Class="SignLanguageLearn.Views.InstructionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Інструкція" Background="{DynamicResource BackgroundBrush}">

    <Page.Resources>
        <Style x:Key="InstructionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#455A64"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="40">
        <Border Background="{DynamicResource CardBrush}" CornerRadius="25" Padding="30" MaxWidth="900">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="📖 Розширений посібник Gesto" FontSize="28" 
                           FontWeight="Bold" Foreground="{DynamicResource TextBrush}" 
                           Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,5,0">
                    <StackPanel Margin="0,0,20,0">

                        <TextBlock Text="🎯 Чому це важливо?" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,10,0,5"/>
                        <TextBlock Text="Мова жестів — це не просто переклад слів рухами. Це візуальна мова зі своєю граматикою та етикетом. Ці поради допоможуть вам стати зрозумілим співрозмовником." 
                                   FontSize="16" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <TextBlock Text="🖐 Провідна рука (Ваш головний інструмент)" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,10,0,5"/>
                        <TextBlock Text="Визначте свою домінантну руку (якою ви пишете). Усі жести, що виконуються однією рукою, мають показуватися саме нею. Якщо жест вимагає двох рук — провідна зазвичай рухається активніше. Головне правило: ніколи не перемикайтеся між руками в межах однієї фрази — це як раптово почати говорити іншим голосом." 
                                   FontSize="16" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <TextBlock Text="🎭 Роль обличчя та міміки" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,10,0,5"/>
                        <TextBlock Text="Близько 60% інформації передається не руками, а виразом обличчя, нахилом голови та положенням тіла. Підняті брови можуть перетворити твердження на запитання. Посмішка або суворість додають жесту забарвлення. Завжди дивіться в обличчя співрозмовнику, а не на його руки." 
                                   FontSize="16" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <TextBlock Text="📐 Зона для жестів (Робочий простір)" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,10,0,5"/>
                        <TextBlock Text="Уявіть навколо себе прозоре вікно від маківки до талії та на ширину плечей. Це ідеальна зона. Не намагайтеся підносити руки надто близько до обличчя (закриваючи рот) або опускати їх надто низько, інакше співрозмовнику доведеться постійно відводити погляд від ваших очей." 
                                   FontSize="16" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <TextBlock Text="🧠 Дактилювання (Алфавіт)" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,10,0,5"/>
                        <TextBlock Text="Алфавіт використовується для імен, власних назв або коли ви не знаєте спеціального жесту для слова. Потрібно показувати літери чітко, але без різких стрибків рукою в сторони. Ваша рука має залишатися майже на одному місці, змінюючи лише форму пальців." 
                                   FontSize="16" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <TextBlock Text="🐢 Темп та чіткість" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,10,0,5"/>
                        <TextBlock Text="Швидкість прийде з часом. На етапі навчання краще показувати повільно, але з точною траєкторією. Використовуйте функції нашого плеєра (равлик/заєць), щоб розібрати складні жести на деталі." 
                                   FontSize="16" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <Border Background="#25FF7675" CornerRadius="10" Padding="15" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="⚠️ Важливий дисклеймер" FontWeight="Bold" Foreground="#FF7675" Margin="0,0,0,10"/>
                                <TextBlock Text="Цей додаток — навчальний тренажер. Жива мова жестів може мати регіональні діалекти. Ми наполегливо рекомендуємо переглядати відео з реальними носіями мови та відвідувати тематичні зустрічі для закріплення навичок." 
                                           FontSize="14" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" FontStyle="Italic"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Button Grid.Row="2" Content="Зрозуміло, до навчання!" Click="Back_Click" Margin="0,20,0,0" 
                        Width="300" Height="50" Style="{StaticResource InstructionButtonStyle}" HorizontalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Page>