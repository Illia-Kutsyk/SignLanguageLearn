<Page x:Class="SignLanguageLearn.Views.TestsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Tests" Background="{DynamicResource PrimaryBackground}">

    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ContentGrid" Storyboard.TargetProperty="Opacity" From="0.0" To="1.0" Duration="0:0:0.4"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>


    <Grid x:Name="ContentGrid" Margin="40">
        <StackPanel>
            <TextBlock Text="{DynamicResource m_Tests}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource MainText}"/>
            <Button Content="{DynamicResource m_Test}" Width="200" Height="50" Margin="0,30" Style="{StaticResource CardButtonStyle}"/>
        </StackPanel>
    </Grid>
</Page>