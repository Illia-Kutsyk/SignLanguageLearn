<Page x:Class="SignLanguageLearn.Views.TestPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Тестування" Background="{DynamicResource BackgroundBrush}">

    <Page.Resources>
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#455A64"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#37474F"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="40">
        <StackPanel x:Name="TestMenu" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Visible">
            <TextBlock Text="Оберіть тему тестування" FontSize="32" FontWeight="Bold" 
                       Foreground="{DynamicResource TextBrush}" Margin="0,0,0,40" HorizontalAlignment="Center"/>

            <UniformGrid Columns="2" Width="650">
                <Button Click="SelectTheme_Click" Tag="Alphabet" Margin="15" Height="200" Style="{StaticResource ModernButtonStyle}">
                    <StackPanel>
                        <TextBlock Text="🔤" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Алфавіт" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Click="SelectTheme_Click" Tag="Phrases" Margin="15" Height="200" Style="{StaticResource ModernButtonStyle}">
                    <StackPanel>
                        <TextBlock Text="👋" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Базові фрази" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </UniformGrid>
        </StackPanel>

        <Grid x:Name="TestInterface" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,20">
                <Button Content="← До тем" Click="BackToMenu_Click" Width="120" Height="40" Style="{StaticResource ModernButtonStyle}"/>
                <TextBlock x:Name="ScoreText" Text="Рахунок: 0/0" DockPanel.Dock="Right" 
                           FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
            </DockPanel>

            <Border Grid.Row="1" Background="Black" CornerRadius="20" ClipToBounds="True" MaxWidth="700">
                <MediaElement x:Name="TestVideo" LoadedBehavior="Manual" UnloadedBehavior="Stop" 
                              Stretch="Uniform" MediaEnded="TestVideo_MediaEnded"/>
            </Border>

            <StackPanel Grid.Row="2" Margin="0,30,0,0">
                <TextBlock Text="Який це жест?" HorizontalAlignment="Center" FontSize="24" 
                           Foreground="{DynamicResource TextBrush}" Margin="0,0,0,20"/>

                <UniformGrid x:Name="AnswersGrid" Columns="3" Height="80">
                    <Button x:Name="Answer1" Click="Answer_Click" Margin="10,0" Style="{StaticResource ModernButtonStyle}"/>
                    <Button x:Name="Answer2" Click="Answer_Click" Margin="10,0" Style="{StaticResource ModernButtonStyle}"/>
                    <Button x:Name="Answer3" Click="Answer_Click" Margin="10,0" Style="{StaticResource ModernButtonStyle}"/>
                </UniformGrid>
            </StackPanel>
        </Grid>
    </Grid>
</Page>