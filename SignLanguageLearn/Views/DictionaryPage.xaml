<Page x:Class="SignLanguageLearn.Views.DictionaryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Словник" Background="{DynamicResource BackgroundBrush}">

    <Page.Resources>
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#455A64"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="40">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="📖 Світовий словник жестів" FontSize="32" FontWeight="Bold" 
                       Foreground="{DynamicResource TextBrush}" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <TextBlock FontSize="18" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" 
                       TextAlignment="Center" Margin="0,0,0,40" Width="500">
                Якщо ви хочете вивчити жести, яких ще немає в нашому застосунку, 
                ви можете скористатися найбільшою світовою базою жестів <Bold>Spreadthesign</Bold>. 
                Там ви знайдете тисячі слів різними мовами, включаючи українську.
            </TextBlock>

            <Button Content="Відкрити словник" Click="OpenWebDictionary_Click" 
                    Width="300" Height="80" Style="{StaticResource ModernButtonStyle}"/>

            <Button Content="← Назад" Click="Back_Click" Margin="0,30,0,0" 
                    Width="120" Height="40" Style="{StaticResource ModernButtonStyle}"/>
        </StackPanel>
    </Grid>
</Page>