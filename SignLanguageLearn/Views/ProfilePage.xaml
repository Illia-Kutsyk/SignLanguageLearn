<Page x:Class="SignLanguageLearn.Views.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Profile" Background="{DynamicResource PrimaryBackground}">

    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ContentGrid" 
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.0" To="1.0" Duration="0:0:0.4"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>

    <Grid x:Name="ContentGrid" Margin="40">
        <StackPanel HorizontalAlignment="Center">
            <Ellipse Width="100" Height="100" Fill="#34495E" Margin="0,0,0,20"/>
            <TextBlock Text="{DynamicResource m_Profile}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource MainText}"/>
            <TextBlock Text="Користувач: Студент" FontSize="16" Foreground="{DynamicResource MainText}" HorizontalAlignment="Center" Margin="0,10"/>
        </StackPanel>
    </Grid>
</Page>