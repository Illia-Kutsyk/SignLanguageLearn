<Page x:Class="SignLanguageLearn.Views.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProfilePage">

    <Grid Background="{DynamicResource BackgroundBrush}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">

            <StackPanel x:Name="AuthBlock" Visibility="Visible">
                <TextBlock Text="Авторизація" 
                           FontSize="28" 
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,25"/>

                <TextBlock Text="Логін" Foreground="{DynamicResource TextBrush}" Margin="0,5" FontSize="14"/>
                <TextBox x:Name="LoginTxt" 
                         Height="40" 
                         TextChanged="LoginTxt_TextChanged"/>

                <TextBlock Text="Пароль" Foreground="{DynamicResource TextBrush}" Margin="0,15,0,5" FontSize="14"/>
                <PasswordBox x:Name="PassBox" 
                             Height="40" />

                <Button Content="Увійти" 
                        Height="45" 
                        Margin="0,30,0,10" 
                        Click="LoginClick" 
                        Cursor="Hand"
                        Background="{DynamicResource AccentBrush}" 
                        Foreground="White"
                        FontSize="16"
                        FontWeight="SemiBold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Створити новий акаунт" 
                        Click="RegisterClick" 
                        Background="Transparent" 
                        Foreground="Gray" 
                        BorderThickness="0" 
                        Cursor="Hand"
                        FontSize="13"/>
            </StackPanel>

            <StackPanel x:Name="ProfileBlock" Visibility="Collapsed">
                <Grid HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Ellipse Width="100" Height="100" Fill="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="👤" FontSize="50" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                </Grid>

                <TextBlock Text="Вітаємо," 
                           FontSize="16" 
                           Foreground="Gray" 
                           HorizontalAlignment="Center"/>

                <TextBlock x:Name="UserNameLbl" 
                           Text="Користувач" 
                           FontSize="32" 
                           FontWeight="ExtraBold" 
                           Foreground="{DynamicResource TextBrush}" 
                           HorizontalAlignment="Center" 
                           Margin="0,5,0,30"/>

                <Border BorderThickness="0,1,0,0" BorderBrush="#20000000" Margin="0,10"/>

                <Button Content="Вийти з профілю" 
                        Height="40" 
                        Width="200" 
                        Margin="0,20" 
                        Click="LogoutClick" 
                        Background="#E74C3C" 
                        Foreground="White"
                        FontWeight="Bold"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="20"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </StackPanel>

        <Border x:Name="NotificationBox" 
                Visibility="Collapsed"
                VerticalAlignment="Top" 
                HorizontalAlignment="Center" 
                Margin="0,20,0,0" 
                Padding="20,10" 
                CornerRadius="10" 
                Background="#2D2D30" 
                BorderThickness="2"
                Panel.ZIndex="1000">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="NotificationText" 
                           Foreground="White" 
                           FontSize="14" 
                           VerticalAlignment="Center"
                           FontWeight="Medium"/>
                <Button Content="✕" 
                        Click="CloseNotification" 
                        Background="Transparent" 
                        Foreground="Gray" 
                        BorderThickness="0" 
                        Margin="15,0,0,0" 
                        Cursor="Hand"
                        FontSize="14"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>