<Page x:Class="SignLanguageLearn.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Settings" Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="40">
        <StackPanel MaxWidth="650" HorizontalAlignment="Left">
            <TextBlock Text="Налаштування" FontSize="32" FontWeight="Bold" 
                       Foreground="{DynamicResource TextBrush}" Margin="0,0,0,30"/>

            <Border Background="{DynamicResource CardBrush}" CornerRadius="20" Padding="30">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Direction="270" Opacity="0.05" ShadowDepth="2"/>
                </Border.Effect>

                <StackPanel>
                    <Grid Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Вибір мови жестів" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                            <TextBlock Text="Виберіть мову для навчання" FontSize="12" Opacity="0.6" Foreground="{DynamicResource TextBrush}"/>
                        </StackPanel>

                        <Border Grid.Column="1" Background="#15000000" CornerRadius="10" Padding="3">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="RbUa" Content="UA" Style="{StaticResource LanguageToggleStyle}" 
                                             GroupName="Langs" Checked="RbUa_Checked"/>
                                <RadioButton x:Name="RbEn" Content="EN" Style="{StaticResource LanguageToggleStyle}" 
                                             GroupName="Langs" Checked="RbEn_Checked"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Separator Opacity="0.1" Margin="0,20,0,25" Background="{DynamicResource TextBrush}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Візуальна тема" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                            <TextBlock Text="Виберіть колірну схему інтерфейсу" FontSize="12" Opacity="0.6" Foreground="{DynamicResource TextBrush}"/>
                        </StackPanel>

                        <Border Grid.Column="1" Background="#15000000" CornerRadius="10" Padding="3">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="RbLight" Content="Light" Style="{StaticResource LanguageToggleStyle}" 
                                             GroupName="Theme" Checked="RbLight_Checked"/>
                                <RadioButton x:Name="RbDark" Content="Dark" Style="{StaticResource LanguageToggleStyle}" 
                                             GroupName="Theme" Checked="RbDark_Checked"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>