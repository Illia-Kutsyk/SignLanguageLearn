<Page x:Class="SignLanguageLearn.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Settings" Background="{DynamicResource PrimaryBackground}">

    <Page.Resources>
        <Style x:Key="LangToggle" TargetType="RadioButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="Width" Value="55"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="Foreground" Value="{DynamicResource MainText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#4CAF50"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="40">
        <StackPanel MaxWidth="650" HorizontalAlignment="Left">
            <TextBlock Text="{DynamicResource m_Settings}" FontSize="32" FontWeight="Bold" 
                       Foreground="{DynamicResource MainText}" Margin="0,0,0,30"/>

            <Border Background="{DynamicResource CardBackground}" CornerRadius="20" Padding="30">
                <StackPanel>
                    <Grid Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{DynamicResource m_Language}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource MainText}"/>
                            <TextBlock Text="Виберіть мову інтерфейсу" FontSize="12" Opacity="0.5" Foreground="{DynamicResource MainText}"/>
                        </StackPanel>

                        <Border Grid.Column="1" Background="#15000000" CornerRadius="10" Padding="3">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="RbUa" Content="UA" Style="{StaticResource LangToggle}" 
                                             GroupName="Langs" Checked="RbUa_Checked" Margin="0,0,3,0"/>
                                <RadioButton x:Name="RbEn" Content="EN" Style="{StaticResource LangToggle}" 
                                             GroupName="Langs" Checked="RbEn_Checked"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Separator Opacity="0.1" Margin="0,0,0,25"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{DynamicResource m_DarkTheme}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource MainText}"/>
                            <TextBlock Text="Використовувати темні кольори" FontSize="12" Opacity="0.5" Foreground="{DynamicResource MainText}"/>
                        </StackPanel>

                        <CheckBox x:Name="ThemeCheckBox" Grid.Column="1" 
                                  Style="{StaticResource ModernToggleStyle}" 
                                  Checked="DarkTheme_Checked" Unchecked="DarkTheme_Unchecked"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>