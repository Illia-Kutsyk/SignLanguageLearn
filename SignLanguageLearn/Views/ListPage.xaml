<Page x:Class="SignLanguageLearn.Views.ListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ListPage" Background="{DynamicResource PrimaryBackground}">
    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ContentGrid" 
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.0" To="1.0" Duration="0:0:0.4"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>

    <Grid x:Name="ContentGrid" Margin="40">
        <StackPanel>
            <TextBlock x:Name="TxtTitle" FontSize="28" FontWeight="Bold" 
                       Foreground="{DynamicResource MainText}" Margin="0,0,0,20"/>

            <Border Background="{DynamicResource CardBackground}" CornerRadius="10" Padding="15">
                <TextBlock Text="Список жестів завантажується..." Foreground="{DynamicResource MainText}"/>
            </Border>
        </StackPanel>
    </Grid>
</Page>