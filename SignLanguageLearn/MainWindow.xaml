<Window x:Class="SignLanguageLearn.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gesto — Платформа навчання" Height="750" Width="1200" 
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen" Background="#F4F7F9">

    <Window.Resources>
        <Style x:Key="BigCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="25" 
                                BorderThickness="0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="40" Color="Black" Opacity="0.1" ShadowDepth="5"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#0F0F15">
            <DockPanel Margin="20">
                <TextBlock DockPanel.Dock="Top" Text="Gesto." Foreground="White" FontSize="34" FontWeight="Black" Margin="0,20,0,60" HorizontalAlignment="Center"/>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,10">
                    <Separator Background="#222" Margin="0,10,0,20"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Name="BtnSettings" Grid.Column="0" Margin="5" Height="45" Background="Transparent" BorderThickness="0" Click="Menu_Click" Cursor="Hand">
                            <TextBlock Text="⚙️ Опції" Foreground="#888"/>
                        </Button>
                        <Button Grid.Column="1" Margin="5" Height="45" Background="Transparent" BorderThickness="0" Click="Exit_Click" Cursor="Hand">
                            <TextBlock Text="🚪 Вихід" Foreground="#FF5C5C"/>
                        </Button>
                    </Grid>
                </StackPanel>

                <StackPanel>
                    <Button Content="🏠 Головна" Height="45" Margin="0,5" Background="#1E1E2D" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button Name="BtnProfile" Content="👤 Профіль" Height="45" Margin="0,5" Background="Transparent" Foreground="#888" BorderThickness="0" Click="Menu_Click" Cursor="Hand"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Навчальна панель" FontSize="36" FontWeight="Bold" Foreground="#2D3436" Margin="20,0,0,30"/>

            <UniformGrid Grid.Row="1" Columns="0" Rows="0">

                <Button Name="BtnLessons" Style="{StaticResource BigCardButtonStyle}" Click="Menu_Click">
                    <StackPanel>
                        <TextBlock Text="📚" FontSize="90" HorizontalAlignment="Center"/>
                        <TextBlock Text="Уроки" FontSize="32" FontWeight="Bold" Foreground="#222" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                        <TextBlock Text="80% готово" FontSize="18" Foreground="#0984E3" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Name="BtnDictionary" Style="{StaticResource BigCardButtonStyle}" Click="Menu_Click">
                    <StackPanel>
                        <TextBlock Text="📖" FontSize="90" HorizontalAlignment="Center"/>
                        <TextBlock Text="Словник" FontSize="32" FontWeight="Bold" Foreground="#222" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                        <TextBlock Text="500+ слів" FontSize="18" Foreground="#00B894" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Name="BtnStats" Style="{StaticResource BigCardButtonStyle}" Click="Menu_Click">
                    <StackPanel>
                        <TextBlock Text="🏆" FontSize="90" HorizontalAlignment="Center"/>
                        <TextBlock Text="Досягнення" FontSize="32" FontWeight="Bold" Foreground="#222" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                        <TextBlock Text="Топ 10" FontSize="18" Foreground="#FD79A8" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Name="BtnQuiz" Style="{StaticResource BigCardButtonStyle}" Click="Menu_Click">
                    <StackPanel>
                        <TextBlock Text="📝" FontSize="90" HorizontalAlignment="Center"/>
                        <TextBlock Text="Тести" FontSize="32" FontWeight="Bold" Foreground="#222" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                        <TextBlock Text="Перевірка" FontSize="18" Foreground="#6C5CE7" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </UniformGrid>
        </Grid>
    </Grid>
</Window>